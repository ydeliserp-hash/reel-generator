# =============================================================================
# Variables de entorno del sistema Reel Generator
# Copia este fichero a `.env` y rellena los valores.
# =============================================================================

# -----------------------------------------------------------------------------
# Groq (Whisper + Llama 3.3 70B). Free tier: https://console.groq.com
# -----------------------------------------------------------------------------
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# Stock providers (ambos free tier)
#   Pexels:  https://www.pexels.com/api/
#   Pixabay: https://pixabay.com/api/docs/
# -----------------------------------------------------------------------------
PEXELS_API_KEY=
PIXABAY_API_KEY=

# -----------------------------------------------------------------------------
# Postgres (la misma instancia que ya usa n8n; crear BD `reels_assets`)
# -----------------------------------------------------------------------------
PG_HOST=postgres
PG_PORT=5432
PG_DB=reels_assets
PG_USER=n8n
PG_PASSWORD=

# -----------------------------------------------------------------------------
# Google Drive (opcional, para upload automatico del reel final)
# Si se deja vacio, el workflow solo devuelve el MP4 en la respuesta del webhook.
# -----------------------------------------------------------------------------
GDRIVE_OUTPUT_FOLDER_ID=

# -----------------------------------------------------------------------------
# FFmpeg worker (DNS interno de EasyPanel)
# -----------------------------------------------------------------------------
FFMPEG_WORKER_URL=http://ffmpeg-reel-worker:3000
FFMPEG_WORKER_TIMEOUT_MS=300000

# -----------------------------------------------------------------------------
# Branding (overrides opcionales — los defaults estan en branding.js)
# -----------------------------------------------------------------------------
BRAND_SIGNATURE=@draydeliserodriguez
